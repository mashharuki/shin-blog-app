{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "**/node_modules",
      "**/build",
      "**/dist",
      "**/coverage",
      "**/temp",
      "**/tmp",
      "**/out",
      "**/target",
      "**/public",
      "**/cdk.out",
      "**/docs",
      "**/aidlc-docs",
      "**/aidlc-inputs",
      "**/.claude/**",
      "**/.github/**",
      "**/.vscode/**",
      "**/.serena/**",
      "**/.aws-aidlc-rule-details/**",
      "**/tsconfig*.json",
      "**/jest.config.*"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    },
    "ignore": []
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  }
}
